# Copier ce fichier en .env et remplir les valeurs
# .env est dans .gitignore — ne jamais committer les credentials

# PostgreSQL — schéma immo_score isolé de Homilink
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# IMPORTANT : en production Docker, utiliser host.docker.internal (pas localhost)
# localhost depuis le container = le container lui-même, pas le VPS host
DATABASE_URL="postgresql://USER:PASSWORD@host.docker.internal:5432/postgres?schema=immo_score"
