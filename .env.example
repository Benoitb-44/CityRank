# Copier ce fichier en .env et remplir les valeurs
# .env est dans .gitignore — ne jamais committer les credentials

# PostgreSQL — service db dédié dans docker-compose.yml
POSTGRES_USER=immo_score
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=immo_score

# DATABASE_URL pointe vers le service "db" (pas localhost ni host.docker.internal)
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# ADEME DPE — API data.ademe.fr (optionnel, accès public en lecture sans clé)
ADEME_API_KEY="your_api_key_here"
