# Copier ce fichier en .env et remplir les valeurs
# .env est dans .gitignore — ne jamais committer les credentials

# PostgreSQL — service db dédié dans docker-compose.yml
POSTGRES_USER=immo_score_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=immo_score

# DATABASE_URL (R/W) — pointe vers le service "db" (pas localhost ni host.docker.internal)
DATABASE_URL="postgresql://immo_score_admin:change_me_strong_password@db:5432/immo_score?schema=immo_score"

# DATABASE_URL_RO (lecture seule) — utilisé par le service mcp-db (INFRA-08)
# Créé par : psql $DATABASE_URL -f scripts/pg-grants-readonly.sql
DATABASE_URL_RO="postgresql://cityrank_ro:change_me_ro_password@db:5432/immo_score?schema=immo_score"

# ADEME DPE — API data.ademe.fr (optionnel, accès public en lecture sans clé)
ADEME_API_KEY="your_api_key_here"
